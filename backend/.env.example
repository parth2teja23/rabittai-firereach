# ─────────────────────────────────────────────────────────────────────────────
# FireReach Backend – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose 'gemini' (Google Gemini) or 'groq' (Llama 3 via Groq)
LLM_PROVIDER=gemini

# Google Gemini API key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY='AIzaSyCh8b2jZfjVuWE88tFt9xH4DLX68WPHAhc'
GEMINI_MODEL="gemini-3-flash-preview"

# Groq API key (only needed if LLM_PROVIDER=groq)
# Get yours at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# ── Tavily Search API ─────────────────────────────────────────────────────────
# Live signal harvesting. Get your key at: https://tavily.com
TAVILY_API_KEY='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'

# ── SMTP (Email Sending) ──────────────────────────────────────────────────────
# For Gmail: enable 2FA and create an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=fredmax3344@gmail.com
# SMTP_PASSWORD='oitimcutwsakjmex'
SMTP_PASSWORD=kiec ieuy rwbs lesd

SMTP_FROM_NAME=FireReach

# ── App ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
DEBUG=false
